# --- Database (PostgreSQL) ---
# Local dev: provisioned by `docker compose up -d db` or `scripts/setup-db.sh`.
# DATABASE_URL is the pooled/runtime connection; DIRECT_URL is a direct session
# connection used for `prisma db push`, migrations, and seeding. Locally they
# can be identical.
DATABASE_URL="postgresql://checkedout:checkedout@localhost:5432/checkedout?schema=public"
DIRECT_URL="postgresql://checkedout:checkedout@localhost:5432/checkedout?schema=public"

# Production (Supabase) example — DATABASE_URL uses the TRANSACTION pooler
# (port 6543, pgbouncer=true), DIRECT_URL uses the SESSION pooler (port 5432):
#   DATABASE_URL="postgresql://postgres.<ref>:<pw>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#   DIRECT_URL="postgresql://postgres.<ref>:<pw>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# --- Auth ---
# Secret used to sign session cookies. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET="please-change-me-to-a-long-random-string"
